{
  "name": "file-organizer",
  "version": "1.0.0",
  "description": "Local File Organizer Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm.cmd run start:backend\" \"npm.cmd run start:frontend\" \"npm.cmd run start:electron\"",
    "dev": "npm.cmd start",
    "start:backend": "cd backend-java && mvn spring-boot:run",
    "start:frontend": "cd frontend && npm.cmd run dev",
    "start:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "npm.cmd run build:backend && npm.cmd run build:frontend && npm.cmd run build:electron",
    "build:backend": "cd backend-java && mvn clean package -DskipTests && copy target\\backend-java-0.0.1-SNAPSHOT.jar ..\\backend-java.jar",
    "build:frontend": "cd frontend && npm.cmd run build",
    "build:electron": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.fileorganizer.app",
    "productName": "File Organizer",
    "directories": {
      "output": "C:/Users/jayaa/file-organizer-build"
    },
    "files": [
      "main.js",
      "backend-java.jar",
      "frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.png"
    }
  }
}
